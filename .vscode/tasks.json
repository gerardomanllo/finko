{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Finko: build web (dev)",
      "type": "shell",
      "command": "flutter build web -t lib/main_dev.dart",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Finko: build web (prod)",
      "type": "shell",
      "command": "flutter build web -t lib/main_prod.dart",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Finko: deploy web (dev)",
      "type": "shell",
      "command": "npm run deploy:web:dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Finko: deploy web (prod)",
      "type": "shell",
      "command": "npm run deploy:web:prod",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
