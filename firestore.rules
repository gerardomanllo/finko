rules_version = '2';

// Deploy: npx -y firebase-tools@latest deploy --only firestore:rules,firestore:indexes
// (confirm active project matches finko-environments / intended env.)

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Global FX cache — written only by Cloud Functions (Admin SDK).
    match /forexRates/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /users/{userId} {
      // Profile document only (not subcollections).
      allow read, write: if signedIn(userId);

      match /monthlyTotals/{monthId} {
        allow read: if signedIn(userId);
        allow write: if false;
      }

      match /_processedAggregateEvents/{eventId} {
        allow read, write: if false;
      }

      match /transactions/{txId} {
        allow read, write: if signedIn(userId);
      }

      match /accounts/{accountId} {
        allow read, write: if signedIn(userId);
      }

      match /categories/{categoryId} {
        allow read, write: if signedIn(userId);
      }

      match /upcomingTransactions/{id} {
        allow read, write: if signedIn(userId);
      }

      match /recurring/{ruleId} {
        allow read, write: if signedIn(userId);
      }
    }
  }
}
