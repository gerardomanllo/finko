rules_version = '2';

// Deploy: npx -y firebase-tools@latest deploy --only firestore:rules,firestore:indexes
// (confirm active project matches finko-environments / intended env.)

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // `users/{uid}/transactions` — server-owned aggregate / audit fields (Functions / Admin SDK only).
    function forbiddenClientTransactionKeys() {
      return [
        'aggregateApplied',
        'aggregateDeferred',
        'reload',
        'aggregateReload',
        'amountMinorMain',
        'fxRateDateUsed'
      ];
    }

    function clientTransactionCreateAllowed() {
      return !forbiddenClientTransactionKeys().hasAny(request.resource.data.keys());
    }

    // Allowlist: only these fields may appear in the update diff. Avoids false
    // positives where `affectedKeys` treats server-owned values as client-changed.
    function clientLedgerTransactionMutableKeys() {
      return [
        'transactionDate',
        'amountMinor',
        'direction',
        'currency',
        'accountId',
        'categoryId',
        'type',
        'memo',
        'transferGroupId',
        'linkedTransactionId',
        'sourceUpcomingId',
        'updatedAt'
      ];
    }

    function clientTransactionUpdateAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(clientLedgerTransactionMutableKeys().toSet());
    }

    function ledgerTransactionCategoryIdOk() {
      return request.resource.data.categoryId is string
        && request.resource.data.categoryId.size() > 0;
    }

    // Global FX cache — written only by Cloud Functions (Admin SDK).
    match /forexRates/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /users/{userId} {
      // Profile document only (not subcollections).
      allow read: if signedIn(userId);
      // Create: `resource` is not defined — do not call `diff(resource.data)`.
      allow create: if signedIn(userId)
        && !request.resource.data.keys().hasAny([
          'onboardingCompleted',
          'integrations',
          'aggregateLastCompletedAt',
          'ledgerSourcesLastChangedAt'
        ]);
      allow update: if signedIn(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'onboardingCompleted',
          'integrations',
          'aggregateLastCompletedAt',
          'ledgerSourcesLastChangedAt'
        ]);
      allow delete: if false;

      match /_onboardingCommits/{requestId} {
        allow read, write: if false;
      }

      match /_otpChallenges/{challengeId} {
        allow read, write: if false;
      }

      match /monthlyTotals/{monthId} {
        allow read: if signedIn(userId);
        allow write: if false;
      }

      match /_processedAggregateEvents/{eventId} {
        allow read, write: if false;
      }

      match /transactions/{txId} {
        allow read: if signedIn(userId);
        allow create: if signedIn(userId)
          && clientTransactionCreateAllowed()
          && ledgerTransactionCategoryIdOk();
        allow update: if signedIn(userId)
          && clientTransactionUpdateAllowed()
          && ledgerTransactionCategoryIdOk();
        allow delete: if signedIn(userId);
      }

      match /accounts/{accountId} {
        allow read, write: if signedIn(userId);
      }

      match /categories/{categoryId} {
        allow read, write: if signedIn(userId);
      }

      match /upcomingTransactions/{id} {
        allow read, write: if signedIn(userId);
      }

      match /recurring/{ruleId} {
        allow read, write: if signedIn(userId);
      }
    }
  }
}
